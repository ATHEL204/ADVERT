# ═══════════════════════════════════════════
# STOREFRONT OS — Git Ignore Rules
# ═══════════════════════════════════════════

# Environment files (NEVER commit these — contain secrets)
.env
*.env
!.env.example

# Dependencies (huge folders — GitHub will reject if too large)
node_modules/
package-lock.json

# Database files
*.db
*.sqlite
*.sqlite3

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*

# Build output
dist/
build/
