# ═══════════════════════════════════════════
# STOREFRONT OS — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database
DB_PATH=./db/storefront.db

# Email (Nodemailer — use Gmail App Password or SMTP relay)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MERCHANT_EMAIL=merchant@yourdomain.com

# Security
JWT_SECRET=change_this_to_a_long_random_string_in_production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# WhatsApp (Twilio optional — fallback to link redirect if not set)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
MERCHANT_WHATSAPP=+1234567890

# Web3 (RPC WebSocket for USDC listener)
RPC_WS_URL=wss://mainnet.base.org/ws
USDC_CONTRACT_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
