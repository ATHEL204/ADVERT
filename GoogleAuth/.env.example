# ═══════════════════════════════════════════════════════
# STOREFRONT OS — Auth Service Environment
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below
# 3. Run: npm start
# ═══════════════════════════════════════════════════════

# Server port — 3005 avoids common collisions
AUTH_PORT=3005
NODE_ENV=development

# Your frontend URL (where login.html is served from)
# If using VS Code Live Server, this is typically:
FRONTEND_URL=http://localhost:5500

# ── Google OAuth ─────────────────────────────────────
# Steps to get these:
# 1. Go to https://console.cloud.google.com
# 2. Create a project (or select existing)
# 3. APIs & Services → OAuth consent screen → set up (External)
# 4. APIs & Services → Credentials → Create → OAuth 2.0 Client ID
# 5. Application type: Web application
# 6. Add to "Authorised JavaScript origins":
#      http://localhost:5500
#      http://localhost:3005
# 7. Add to "Authorised redirect URIs":
#      http://localhost:3005/auth/google/callback
# 8. Copy the Client ID and Secret below

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3005/auth/google/callback

# ── JWT ──────────────────────────────────────────────
# Generate a secure secret by running this in your terminal:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Then paste the output below:
JWT_SECRET=replace_this_with_your_generated_secret
JWT_EXPIRES_IN=7d

# ── Gmail SMTP ────────────────────────────────────────
# Steps to get a Gmail App Password:
# 1. Enable 2-Step Verification on your Google account
# 2. Go to: myaccount.google.com → Security → App Passwords
# 3. Select "Mail" and your device → Generate
# 4. Copy the 16-character password (no spaces) below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_NAME=STOREFRONT OS
EMAIL_FROM_ADDRESS=your-gmail@gmail.com

# ── Token Expiry ─────────────────────────────────────
EMAIL_TOKEN_EXPIRES_MINUTES=60
RESET_TOKEN_EXPIRES_MINUTES=15
COOKIE_SECURE=false
